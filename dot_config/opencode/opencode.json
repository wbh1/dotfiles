{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "python3 *": "allow",
      "uv *": "allow",
      "mkdir *": "allow",
      "ls *": "allow",
      "mise run *": "allow",
      "make test": "allow",
      "make build": "allow",
      "git worktree *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "go test *": "allow",
      "go mod *": "allow",
      "go fmt *": "allow",
      "go vet *": "allow",
      "go run *": "allow",
      "go list *": "allow",
      "go get *": "allow",
      "which *": "allow",
      "pwd": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "jira *": "allow"
    },
    "webfetch": "ask",
    "skill": {
      "superpowers*": "allow",
      "jira": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:~/.config/context7/key}"
      },
      "enabled": true
    },
    "jirapy": {
      "type": "local",
      "command": [
        "jirapy-mcp"
      ],
      "enabled": true
    }
  }
}
