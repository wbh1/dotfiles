{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(python3 *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(mise run *)",
      "Bash(git worktree *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(make test:*)",
      "Bash(make build:*)",
      "Bash(pwd)",
      "Skill(superpowers:*)",
      "SlashCommand(/superpowers:*)",
      "WebFetch(domain:code.claude.com)"
    ]
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "model": "opus",
  "sandbox": {
    "enabled": true
  }
}
