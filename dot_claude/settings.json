{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(python3 *)",
      "Bash(uv *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(mise run *)",
      "Bash(git worktree *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(make test:*)",
      "Bash(make build:*)",
      "Bash(pwd)",
      "Skill(superpowers:*)",
      "Skill(jira)",
      "Read(~/.claude/skills/jira/*)",
      "SlashCommand(/superpowers:*)",
      "WebFetch(domain:code.claude.com)"
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowUnixSockets": [
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
